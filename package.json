{
  "name": "@brixus365/mcp-server",
  "version": "0.1.0",
  "description": "Model Context Protocol server for the Brixus Email API. Lets LLM agents send transactional email through Brixus using starter templates.",
  "license": "MIT",
  "author": "Brixus <hello@brixus365.com>",
  "homepage": "https://brixus365.com/developers",
  "repository": {
    "type": "git",
    "url": "https://github.com/Brixus-Technologies/brixus365-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Brixus-Technologies/brixus365-mcp/issues"
  },
  "keywords": ["mcp", "model-context-protocol", "email", "brixus365", "claude"],
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "brixus365-mcp-server": "dist/index.js"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
